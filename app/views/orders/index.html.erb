<% content_for :title, "Order Management" %>
<% content_for :head do %>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      background-color: #f8f9fa;
      color: #333;
      line-height: 1.4;
      font-size: 14px;
    }

    .main-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    .header {
      background: #ffffff;
      border: 1px solid #dee2e6;
      border-radius: 6px 6px 0 0;
      padding: 15px 20px;
      border-bottom: none;
    }

    .header h1 {
      font-size: 20px;
      font-weight: 600;
      color: #495057;
      margin: 0;
    }

    .control-panel {
      background: #ffffff;
      border: 1px solid #dee2e6;
      border-top: none;
      padding: 12px 20px;
      display: flex;
      gap: 8px;
      align-items: center;
      border-bottom: 1px solid #dee2e6;
    }

    .btn {
      padding: 6px 12px;
      border: 1px solid #ced4da;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      transition: all 0.15s ease;
      background: #ffffff;
      color: #495057;
      text-decoration: none;
      min-width: 60px;
      justify-content: center;
    }

    .btn i {
      font-size: 11px;
    }

    .btn-add {
      background: #28a745;
      color: white;
      border-color: #28a745;
    }

    .btn-add:hover {
      background: #218838;
      border-color: #1e7e34;
    }

    .btn-edit {
      background: #007bff;
      color: white;
      border-color: #007bff;
    }

    .btn-edit:hover {
      background: #0056b3;
      border-color: #0056b3;
    }

    .btn-delete {
      background: #dc3545;
      color: white;
      border-color: #dc3545;
    }

    .btn-delete:hover {
      background: #c82333;
      border-color: #bd2130;
    }

    .btn-update {
      background: #ffc107;
      color: #212529;
      border-color: #ffc107;
    }

    .btn-update:hover {
      background: #e0a800;
      border-color: #d39e00;
    }

    .btn-cancel {
      background: #6c757d;
      color: white;
      border-color: #6c757d;
    }

    .btn-cancel:hover {
      background: #545b62;
      border-color: #4e555b;
    }

    .btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      background: #e9ecef !important;
      color: #6c757d !important;
      border-color: #dee2e6 !important;
    }

    .btn:disabled:hover {
      background: #e9ecef !important;
      color: #6c757d !important;
      border-color: #dee2e6 !important;
    }

    .table-wrapper {
      background: #ffffff;
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 6px 6px;
      overflow: hidden;
    }

    .table-container {
      max-height: 400px;
      overflow-y: auto;
      overflow-x: auto;
    }

    .orders-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      font-size: 13px;
    }

    .orders-table th {
      background: #f8f9fa;
      color: #495057;
      font-weight: 600;
      padding: 10px 12px;
      text-align: left;
      border-bottom: 2px solid #dee2e6;
      position: sticky;
      top: 0;
      z-index: 10;
      font-size: 13px;
    }

    .orders-table td {
      padding: 8px 12px;
      border-bottom: 1px solid #dee2e6;
      vertical-align: middle;
      font-size: 13px;
    }

    .orders-table tr:hover:not(.editing):not(.selected) {
      background-color: #f8f9fa;
    }

    .orders-table tr.selected {
      background-color: #e3f2fd;
    }

    .orders-table tr.editing {
      background-color: #fff3cd;
    }

    .order-id {
      font-weight: 600;
      color: #495057;
    }

    .freight {
      color: #28a745;
      font-weight: 500;
    }

    .input-field {
      width: 100%;
      padding: 4px 6px;
      border: 1px solid #ced4da;
      border-radius: 3px;
      font-size: 13px;
      background: white;
      font-family: inherit;
    }

    .input-field:focus {
      outline: none;
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .number-input {
      width: 70px;
      text-align: right;
    }

    .select-field {
      width: 100%;
      padding: 4px 6px;
      border: 1px solid #ced4da;
      border-radius: 3px;
      font-size: 13px;
      background: white;
      cursor: pointer;
      font-family: inherit;
    }

    .select-field:focus {
      outline: none;
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .scrollbar {
      scrollbar-width: thin;
      scrollbar-color: #adb5bd #f8f9fa;
    }

    .scrollbar::-webkit-scrollbar {
      width: 8px;
    }

    .scrollbar::-webkit-scrollbar-track {
      background: #f8f9fa;
    }

    .scrollbar::-webkit-scrollbar-thumb {
      background: #adb5bd;
      border-radius: 4px;
    }

    .scrollbar::-webkit-scrollbar-thumb:hover {
      background: #6c757d;
    }

    .notification {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 12px 16px;
      border-radius: 4px;
      color: white;
      font-weight: 500;
      z-index: 1000;
      font-size: 13px;
      animation: slideIn 0.3s ease;
    }

    .notification.success {
      background: #28a745;
    }

    .notification.error {
      background: #dc3545;
    }

    .notification.info {
      background: #17a2b8;
    }

    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  </style>
<% end %>

<div class="main-container">
  <div class="header">
    <h1>Order Management</h1>
  </div>

  <% if notice %>
    <div class="notification success" style="position: relative; margin: 10px 0;">
      <%= notice %>
    </div>
  <% end %>

  <% if alert %>
    <div class="notification error" style="position: relative; margin: 10px 0;">
      <%= alert %>
    </div>
  <% end %>

  <div class="control-panel">
    <a class="btn btn-add" id="addBtn" href="<%= new_order_path %>">
      <i class="fas fa-plus"></i>
      Add
    </a>
    <button class="btn btn-edit" id="editBtn" onclick="editOrder()">
      <i class="fas fa-edit"></i>
      Edit
    </button>
    <button class="btn btn-delete" id="deleteBtn" onclick="deleteOrder()">
      <i class="fas fa-trash"></i>
      Delete
    </button>
    <button class="btn btn-update" id="updateBtn" onclick="updateOrder()" disabled>
      <i class="fas fa-arrow-down"></i>
      Update
    </button>
    <button class="btn btn-cancel" id="cancelBtn" onclick="cancelEdit()" disabled>
      <i class="fas fa-times"></i>
      Cancel
    </button>
  </div>

  <div class="table-wrapper">
    <div class="table-container scrollbar">
      <table class="orders-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Customer Name</th>
            <th>Freight</th>
            <th>Ship Name</th>
            <th>Ship Country</th>
          </tr>
        </thead>
        <tbody id="ordersTableBody">
          <% @orders.each do |order| %>
            <tr data-id="<%= order.id %>">
              <td class="order-id"><%= order.id %></td>
              <td><%= order.customer_name %></td>
              <td class="freight"><%= order.formatted_freight %></td>
              <td><%= order.ship_name %></td>
              <td><%= order.ship_country %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  let currentEditRow = null;
  let originalData = {};

  function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `notification ${type}`;
    notification.textContent = message;
    document.body.appendChild(notification);

    setTimeout(() => {
      notification.remove();
    }, 3000);
  }

  function setButtonStates(editing) {
    const addBtn = document.getElementById('addBtn');
    const editBtn = document.getElementById('editBtn');
    const deleteBtn = document.getElementById('deleteBtn');
    const updateBtn = document.getElementById('updateBtn');
    const cancelBtn = document.getElementById('cancelBtn');

    if (editing) {
      addBtn.disabled = true;
      editBtn.disabled = true;
      deleteBtn.disabled = true;
      updateBtn.disabled = false;
      cancelBtn.disabled = false;
    } else {
      addBtn.disabled = false;
      editBtn.disabled = false;
      deleteBtn.disabled = false;
      updateBtn.disabled = true;
      cancelBtn.disabled = true;
    }
  }

  function editOrder() {
    const selectedRow = document.querySelector('tr.selected');
    if (!selectedRow) {
      showNotification('Please select a row to edit', 'error');
      return;
    }

    currentEditRow = selectedRow;
    const rowId = currentEditRow.dataset.id;
    
    // Store original data
    originalData = {
      customerName: currentEditRow.cells[1].textContent,
      freight: currentEditRow.cells[2].textContent.replace('$', ''),
      shipName: currentEditRow.cells[3].textContent,
      shipCountry: currentEditRow.cells[4].textContent
    };

    // Convert to editable fields
    currentEditRow.cells[1].innerHTML = `<input type="text" class="input-field" value="${originalData.customerName}">`;
    currentEditRow.cells[2].innerHTML = `<input type="number" class="input-field number-input" value="${originalData.freight}" step="0.01">`;
    currentEditRow.cells[3].innerHTML = `<input type="text" class="input-field" value="${originalData.shipName}">`;
    currentEditRow.cells[4].innerHTML = `
      <select class="select-field">
        <option value="Germany" ${originalData.shipCountry === 'Germany' ? 'selected' : ''}>Germany</option>
        <option value="France" ${originalData.shipCountry === 'France' ? 'selected' : ''}>France</option>
        <option value="Brazil" ${originalData.shipCountry === 'Brazil' ? 'selected' : ''}>Brazil</option>
        <option value="Belgium" ${originalData.shipCountry === 'Belgium' ? 'selected' : ''}>Belgium</option>
        <option value="Switzerland" ${originalData.shipCountry === 'Switzerland' ? 'selected' : ''}>Switzerland</option>
        <option value="Venezuela" ${originalData.shipCountry === 'Venezuela' ? 'selected' : ''}>Venezuela</option>
        <option value="United States" ${originalData.shipCountry === 'United States' ? 'selected' : ''}>United States</option>
        <option value="Spain" ${originalData.shipCountry === 'Spain' ? 'selected' : ''}>Spain</option>
        <option value="Canada" ${originalData.shipCountry === 'Canada' ? 'selected' : ''}>Canada</option>
        <option value="United Kingdom" ${originalData.shipCountry === 'United Kingdom' ? 'selected' : ''}>United Kingdom</option>
        <option value="Australia" ${originalData.shipCountry === 'Australia' ? 'selected' : ''}>Australia</option>
      </select>
    `;

    currentEditRow.classList.add('editing');
    setButtonStates(true);
    showNotification('Row is now in edit mode', 'info');
  }

  function deleteOrder() {
    const selectedRow = document.querySelector('tr.selected');
    if (!selectedRow) {
      showNotification('Please select a row to delete', 'error');
      return;
    }

    if (confirm('Are you sure you want to delete this order?')) {
      const orderId = selectedRow.dataset.id;
      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      
      // Send delete request to Rails backend
      fetch(`/orders/${orderId}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': csrfToken,
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        }
      })
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
      })
      .then(data => {
        if (data.success) {
          selectedRow.remove();
          showNotification('Order deleted successfully', 'success');
        } else {
          showNotification(data.message || 'Failed to delete order', 'error');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        // Check if it's a JSON parsing error (which might indicate success)
        if (error.message.includes('JSON')) {
          // If we can't parse JSON but the row was removed, it might be successful
          selectedRow.remove();
          showNotification('Order deleted successfully', 'success');
        } else {
          showNotification('Error deleting order: ' + error.message, 'error');
        }
      });
    }
  }

  function updateOrder() {
    if (!currentEditRow) return;

    const orderId = currentEditRow.dataset.id;
    const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    
    // Get updated values
    const customerName = currentEditRow.cells[1].querySelector('input').value;
    const freight = currentEditRow.cells[2].querySelector('input').value;
    const shipName = currentEditRow.cells[3].querySelector('input').value;
    const shipCountry = currentEditRow.cells[4].querySelector('select').value;

    // Validate required fields
    if (!customerName || !freight || !shipName || !shipCountry) {
      showNotification('All fields are required', 'error');
      return;
    }

    // Send update request to Rails backend
    fetch(`/orders/${orderId}`, {
      method: 'PATCH',
      headers: {
        'X-CSRF-Token': csrfToken,
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        order: {
          customer_name: customerName,
          freight: freight,
          ship_name: shipName,
          ship_country: shipCountry
        }
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      if (data.success) {
        // Update the row
        currentEditRow.cells[1].textContent = customerName;
        currentEditRow.cells[2].textContent = `$${parseFloat(freight).toFixed(2)}`;
        currentEditRow.cells[3].textContent = shipName;
        currentEditRow.cells[4].textContent = shipCountry;

        currentEditRow.classList.remove('editing');
        currentEditRow = null;
        originalData = {};
        setButtonStates(false);

        showNotification('Order updated successfully', 'success');
      } else {
        showNotification(data.message || 'Failed to update order', 'error');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      // Check if it's a JSON parsing error (which might indicate success)
      if (error.message.includes('JSON')) {
        // If we can't parse JSON but the data looks good, update the row anyway
        currentEditRow.cells[1].textContent = customerName;
        currentEditRow.cells[2].textContent = `$${parseFloat(freight).toFixed(2)}`;
        currentEditRow.cells[3].textContent = shipName;
        currentEditRow.cells[4].textContent = shipCountry;

        currentEditRow.classList.remove('editing');
        currentEditRow = null;
        originalData = {};
        setButtonStates(false);

        showNotification('Order updated successfully', 'success');
      } else {
        showNotification('Error updating order: ' + error.message, 'error');
      }
    });
  }

  function cancelEdit() {
    if (currentEditRow) {
      // Restore original data
      currentEditRow.cells[1].textContent = originalData.customerName;
      currentEditRow.cells[2].textContent = `$${parseFloat(originalData.freight).toFixed(2)}`;
      currentEditRow.cells[3].textContent = originalData.shipName;
      currentEditRow.cells[4].textContent = originalData.shipCountry;

      currentEditRow.classList.remove('editing');
      currentEditRow = null;
      originalData = {};
    }
    setButtonStates(false);
    showNotification('Edit cancelled', 'info');
  }

  // Row selection functionality
  document.addEventListener('DOMContentLoaded', function() {
    const tableBody = document.getElementById('ordersTableBody');
    
    tableBody.addEventListener('click', function(e) {
      const row = e.target.closest('tr');
      if (!row) return;

      // Remove selection from all rows
      document.querySelectorAll('tr').forEach(r => r.classList.remove('selected'));
      
      // Add selection to clicked row
      row.classList.add('selected');
    });

    // Auto-hide flash messages after 3 seconds
    const flashMessages = document.querySelectorAll('.notification');
    flashMessages.forEach(function(message) {
      setTimeout(function() {
        message.style.opacity = '0';
        setTimeout(function() {
          message.remove();
        }, 300);
      }, 3000);
    });
  });
</script>
