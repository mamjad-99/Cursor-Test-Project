<% content_for :head do %>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      background-color: #f8f9fa;
      color: #333;
      line-height: 1.4;
      font-size: 14px;
    }

    .main-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    .header {
      background: #ffffff;
      border: 1px solid #dee2e6;
      border-radius: 6px 6px 0 0;
      padding: 15px 20px;
      border-bottom: none;
    }

    .header h1 {
      font-size: 20px;
      font-weight: 600;
      color: #495057;
      margin: 0;
    }

    .btn {
      padding: 6px 12px;
      border: 1px solid #ced4da;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      transition: all 0.15s ease;
      background: #ffffff;
      color: #495057;
      text-decoration: none;
      min-width: 60px;
      justify-content: center;
    }

    .btn-add {
      background: #28a745;
      color: white;
      border-color: #28a745;
    }

    .btn-add:hover {
      background: #218838;
      border-color: #1e7e34;
    }

    .btn-cancel {
      background: #6c757d;
      color: white;
      border-color: #6c757d;
    }

    .btn-cancel:hover {
      background: #545b62;
      border-color: #4e555b;
    }

    .table-wrapper {
      background: #ffffff;
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 6px 6px;
      overflow: hidden;
    }

    .input-field {
      width: 100%;
      padding: 4px 6px;
      border: 1px solid #ced4da;
      border-radius: 3px;
      font-size: 13px;
      background: white;
      font-family: inherit;
    }

    .input-field:focus {
      outline: none;
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .number-input {
      width: 70px;
      text-align: right;
    }

    .select-field {
      width: 100%;
      padding: 4px 6px;
      border: 1px solid #ced4da;
      border-radius: 3px;
      font-size: 13px;
      background: white;
      cursor: pointer;
      font-family: inherit;
    }

    .select-field:focus {
      outline: none;
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .notification {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 12px 16px;
      border-radius: 4px;
      color: white;
      font-weight: 500;
      z-index: 1000;
      font-size: 13px;
      animation: slideIn 0.3s ease;
    }

    .notification.error {
      background: #dc3545;
    }

    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
  </style>
<% end %>

<div class="main-container">
  <div class="header">
    <h1>Add New Order</h1>
  </div>
  <div class="table-wrapper" style="padding: 32px 24px; max-width: 600px; margin: 32px auto;">
    <%= form_with(model: @order, local: true, data: { turbo: false }) do |form| %>
      <% if @order.errors.any? %>
        <div class="notification error" style="margin-bottom: 16px;">
          <strong><%= pluralize(@order.errors.count, "error") %> prohibited this order from being saved:</strong>
          <ul>
            <% @order.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div style="display: flex; flex-direction: column; gap: 18px;">
        <div>
          <label>Customer Name</label><br>
          <%= form.text_field :customer_name, class: "input-field", required: true, autofocus: true %>
        </div>
        <div>
          <label>Freight</label><br>
          <%= form.number_field :freight, class: "input-field number-input", step: 0.01, min: 0, required: true %>
        </div>
        <div>
          <label>Ship Name</label><br>
          <%= form.text_field :ship_name, class: "input-field", required: true %>
        </div>
        <div>
          <label>Ship Country</label><br>
          <%= form.select :ship_country, ["Germany", "France", "Brazil", "Belgium", "Switzerland", "Venezuela", "United States", "Spain", "Canada", "United Kingdom", "Australia"], {}, class: "select-field", required: true %>
        </div>
        <div style="margin-top: 18px; display: flex; gap: 12px;">
          <%= form.submit "Save", class: "btn btn-add" %>
          <%= link_to "Cancel", orders_path, class: "btn btn-cancel" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
